# HomeGrown — environment template.
# Copy to .env (gitignored) locally; in GCP, values come from Secret Manager.
# NEVER commit a filled-in .env. The legacy repo leaked credentials — all were rotated.

# --- Server (apps/server) ---
# Cloud Run sets PORT; default to 3001 locally.
PORT=3001
NODE_ENV=development

# Postgres + PostGIS. Matches docker-compose.yml for local dev.
DATABASE_URL=postgres://homegrown:homegrown@localhost:5432/homegrown

# Auth — secret for signing/verifying self-issued JWTs (HS256).
# Generate a strong random value, e.g.:  openssl rand -base64 48
# Min 32 chars (enforced by env validation). NEVER commit a real secret; no source fallback.
JWT_SECRET=

# Geocoding — Google Geocoding API key (server-side; address → lat/lng at store creation).
# Restrict the key to the Geocoding API in the GCP console. From env locally; Secret Manager in deploys.
GOOGLE_GEOCODING_API_KEY=

# --- Mobile (apps/mobile) ---
# Only EXPO_PUBLIC_* vars are exposed to the client bundle. No secrets here, ever.
EXPO_PUBLIC_API_URL=http://localhost:3001

# Stripe — Connect Express + PaymentSheet (M4 Payments backbone).
# RECOMMENDED: use a restricted key (rk_test_… / rk_live_…) scoped to least privilege.
# Secret keys (sk_…) are also accepted. Publishable keys (pk_…) are REJECTED by env validation.
# NEVER commit real values. Both are required at runtime.
STRIPE_SECRET_KEY=
# Stripe webhook signing secret for the "Your account" (platform) destination.
# Handles payment_intent.* events. Found in Stripe Dashboard → Webhooks → [platform endpoint].
STRIPE_WEBHOOK_SECRET=
# Stripe webhook signing secret for the "Connected accounts" destination.
# Handles account.updated events. A SEPARATE secret from STRIPE_WEBHOOK_SECRET —
# each Stripe webhook endpoint has its own whsec_… signing secret.
# Found in Stripe Dashboard → Webhooks → [connected accounts endpoint].
# Required: missing at boot = loud failure (prevents silently dropped connect-account events).
STRIPE_WEBHOOK_SECRET_CONNECT=

# Stripe Connect redirect URLs — built server-side (prevents open-redirect, issue #7).
# NOT secrets — no key material. Safe to set in Cloud Run env vars or .env.
# Override for local dev (e.g. ngrok tunnel) or staging; defaults shown below are production.
STRIPE_CONNECT_REFRESH_URL=https://homegrown.app/connect/refresh
STRIPE_CONNECT_RETURN_URL=https://homegrown.app/connect/return

# --- Mobile (M4b — Stripe PaymentSheet + Connect onboarding) ---
# Stripe publishable key (pk_test_… for local dev; pk_live_… via Secret Manager in prod).
# This key is intentionally client-safe: Stripe publishable keys carry no secret authority
# and are designed to be embedded in client bundles. It is exposed to the Expo bundle via
# EXPO_PUBLIC_ prefix. Secret keys (sk_…) and webhook secrets (whsec_…) are server-only
# (see STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET above). Supply this before live payment testing.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
