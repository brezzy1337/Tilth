# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Secrets — NEVER commit. The legacy repo leaked credentials; all config is env-driven.
.env
.env.*
!.env.example

# Expo / React Native
.expo/
.expo-shared/
apps/mobile/ios/
apps/mobile/android/
*.jks
*.p8
*.p12
*.mobileprovision
*.orig.*

# Drizzle
apps/server/drizzle/meta/_journal.json.lock

# Test / coverage
coverage/
.vitest/

# Claude Code — local config, not shared
.claude/

# Terraform — state, vars files, and provider cache must never be committed.
# terraform.tfvars can contain project IDs and other values that vary per
# environment. Use terraform.tfvars.example as the committed template.
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.auto.tfvars
# NOTE: .terraform.lock.hcl IS committed (provider-version pinning, like pnpm-lock.yaml).

# Local Google Cloud SDK install (do not commit toolchain into the repo).
google-cloud-sdk/
google-cloud-cli-*.tar.gz

# Editor / OS
.DS_Store
*.log
.idea/
.vscode/*
!.vscode/extensions.json
apps/server/scripts/.test-accounts.json
